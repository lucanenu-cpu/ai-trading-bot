OPENAI_API_KEY=sk-your-key-here
NEWS_API_KEY=your-newsapi-key
WEBHOOK_SECRET=changeme
PORT=5000
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TWILIO_SID=optional
TWILIO_AUTH_TOKEN=optional
TWILIO_FROM=optional
TWILIO_TO=optional

# ── Risk & Strategy ──────────────────────────────────────────────────
# Account balance used for position sizing
ACCOUNT_BALANCE_USD=1000
# Maximum risk per trade as % of balance (1 = 1 %)
RISK_PER_TRADE_PCT=1.0
# Maximum total loss per day as % of balance before new trades are blocked
MAX_DAILY_LOSS_PCT=3.0
# Maximum number of trades allowed per calendar day
MAX_TRADES_PER_DAY=5
# Maximum simultaneous open positions
MAX_OPEN_POSITIONS=3

# ── Signal Thresholds ────────────────────────────────────────────────
# Minimum score (0-100) required to emit a BUY or SELL signal
MIN_SIGNAL_SCORE=65
# Score above which full position sizing is used
STRONG_SIGNAL_SCORE=80

# ── Stop-Loss / Take-Profit ──────────────────────────────────────────
# Fixed default SL distance in % (used when ATR_SL_MULTIPLIER=0)
DEFAULT_STOP_LOSS_PCT=2.0
# Fixed default TP distance in %
DEFAULT_TAKE_PROFIT_PCT=4.0
# ATR multiplier for dynamic SL (0 = disabled, use fixed %)
ATR_SL_MULTIPLIER=2.0

# ── Advanced Safety ──────────────────────────────────────────────────
# Minimum seconds between consecutive trades on the same symbol (0 = disabled)
TRADE_COOLDOWN_SECS=300
# ADX below this value = choppy market; new trades are skipped (0 = disabled)
CHOP_ADX_THRESHOLD=20.0

# ── AI Guardrails ────────────────────────────────────────────────────
MAX_AI_CALLS_PER_HOUR=20
AI_ENABLED=true
OPENAI_MODEL=gpt-4o

